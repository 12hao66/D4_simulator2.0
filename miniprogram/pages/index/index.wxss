.container {
  height: 100vh;
  background: #0f0f1a;
  display: flex;
  flex-direction: column;
}

.navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 88rpx;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
  z-index: 100;
  border-bottom: 1rpx solid rgba(224, 160, 32, 0.2);
}

.navbar-title {
  font-family: 'Cinzel', serif;
  font-size: 32rpx;
  font-weight: 700;
  color: #ffd060;
  letter-spacing: 2rpx;
}

.navbar-right {
  display: flex;
  align-items: center;
}

.share-btn {
  padding: 12rpx 24rpx;
  background: rgba(224, 160, 32, 0.2);
  border: 1rpx solid rgba(224, 160, 32, 0.4);
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #ffd060;
}

.webview {
  flex: 1;
  margin-top: 88rpx;
}

.float-actions {
  position: fixed;
  right: 32rpx;
  bottom: 120rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 28rpx;
  border-radius: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.3);
}

.action-btn.primary {
  background: linear-gradient(135deg, #e0a020 0%, #b45808 100%);
}

.action-icon {
  font-size: 32rpx;
}

.action-text {
  font-size: 26rpx;
  color: #fff;
  font-weight: 600;
}

/* 分享弹窗 */
.share-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 600rpx;
  background: #1a1a2e;
  border-radius: 24rpx;
  border: 2rpx solid rgba(224, 160, 32, 0.3);
  overflow: hidden;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.modal-title {
  font-family: 'Cinzel', serif;
  font-size: 32rpx;
  font-weight: 700;
  color: #ffd060;
}

.modal-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #999;
}

.modal-body {
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.share-preview {
  background: #0f0f1a;
  border-radius: 16rpx;
  padding: 16rpx;
  margin-bottom: 20rpx;
}

.share-canvas {
  border-radius: 12rpx;
}

.preview-hint {
  font-size: 24rpx;
  color: #999;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
}

.btn {
  flex: 1;
  padding: 24rpx;
  border-radius: 16rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
}

.btn-primary {
  background: linear-gradient(135deg, #e0a020 0%, #b45808 100%);
  color: #fff;
}

.btn-secondary {
  background: rgba(255, 255, 255, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  color: #ccc;
}
