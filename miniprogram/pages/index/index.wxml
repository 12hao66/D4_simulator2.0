<view class="container">
  <!-- 顶部导航栏 -->
  <view class="navbar">
    <view class="navbar-title">⚔️ D4伤害计算器</view>
    <view class="navbar-right">
      <view class="share-btn" bindtap="showShareMenu">
        <text>📤 分享</text>
      </view>
    </view>
  </view>

  <!-- WebView 嵌入网页 -->
  <web-view 
    src="https://12hao66.github.io/D4_simulator/index.html" 
    class="webview"
    bindmessage="onWebViewMessage"
  ></web-view>

  <!-- 悬浮操作按钮 -->
  <view class="float-actions">
    <view class="action-btn primary" bindtap="generateShareImage">
      <text class="action-icon">🎨</text>
      <text class="action-text">生成分享图</text>
    </view>
  </view>

  <!-- 分享弹窗 -->
  <view class="share-modal" wx:if="{{showModal}}">
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">🎨 生成分享图</text>
        <view class="modal-close" bindtap="closeModal">×</view>
      </view>
      <view class="modal-body">
        <view class="share-preview">
          <canvas 
            canvas-id="shareCanvas" 
            class="share-canvas"
            style="width: 300px; height: 450px;"
          ></canvas>
        </view>
        <view class="preview-hint">点击下方按钮保存或分享</view>
      </view>
      <view class="modal-footer">
        <view class="btn btn-secondary" bindtap="saveImage">💾 保存到相册</view>
        <view class="btn btn-primary" bindtap="shareImage">📤 分享给好友</view>
      </view>
    </view>
  </view>
</view>
